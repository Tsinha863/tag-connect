rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Note: Using get() has cost implications (1 read per request).
    // It is used here for critical role-based access control.
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    function isRequestingUserACompany() {
      return isSignedIn() && getRole() == 'company';
    }
    
    function isOwnerAsRole(userId, role) {
      return isOwner(userId) && getRole() == role;
    }

    // --------------------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------------------

    match /users/{userId} {
      // Admins have full access. Users can manage their own document.
      allow read, write: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
    }

    match /studentProfiles/{studentId} {
      // Students can write to their own profile. Admins can also write.
      allow create: if isOwnerAsRole(studentId, 'student') || isAdmin();
      allow update, delete: if isOwner(studentId) || isAdmin();

      // Only the owner or an admin can view a full student profile.
      // Companies can see applicant details via the Application document.
      allow get: if isOwner(studentId) || isAdmin();
      allow list: if isAdmin();
    }

    match /companyProfiles/{companyId} {
      // Companies can write their own profile. Admins can also write.
      allow create: if isOwnerAsRole(companyId, 'company') || isAdmin();
      allow update, delete: if isOwner(companyId) || isAdmin();
      
      // Any signed-in user can view a company profile. Admins can list all.
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }

    match /jobs/{jobId} {
      // Job listings are public to read.
      allow get, list: if true;

      // Only the owning company or an admin can create, update, or delete jobs.
      allow create: if isOwnerAsRole(request.resource.data.companyId, 'company') || isAdmin();
      allow update, delete: if isOwnerAsRole(resource.data.companyId, 'company') || isAdmin();
    }

    match /applications/{applicationId} {
      // Only a student can create an application for themselves.
      allow create: if isOwnerAsRole(request.resource.data.studentId, 'student');
      
      // The involved student, company, or an admin can read/delete.
      allow get, delete: if isOwner(resource.data.studentId) || isOwner(resource.data.companyId) || isAdmin();
      
      // Only the company or an admin can update the application status.
      allow update: if isOwner(resource.data.companyId) || isAdmin();

      // Students can query their own applications.
      // Companies can query applications for their jobs.
      // Admins can query anything.
      allow list: if (getRole() == 'student' && request.query.where.studentId == request.auth.uid) ||
                     (getRole() == 'company' && request.query.where.companyId == request.auth.uid) ||
                     (getRole() == 'company' && isOwner(get(/databases/$(database)/documents/jobs/$(request.query.where.jobId)).data.companyId)) ||
                     isAdmin();
    }

    match /placements/{placementId} {
      // Only admins can manage placement records.
      allow read, write: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      // Anyone can submit an inquiry.
      allow create: if true;
      // Only admins can manage inquiries.
      allow read, write: if isAdmin();
    }
  }
}

    